NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://ethereum.publicnode.com
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arbitrum-one-rpc.publicnode.com

# Optional backend endpoints for production wallet authentication.
# If these are not implemented yet, the frontend falls back to local demo signing.
