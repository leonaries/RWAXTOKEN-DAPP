NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://ethereum.publicnode.com
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arbitrum-one-rpc.publicnode.com

# Optional backend endpoints for production wallet authentication.
# If these are not implemented yet, the frontend falls back to local demo signing.
NEXT_PUBLIC_WALLET_NONCE_ENDPOINT=/api/auth/wallet/nonce
NEXT_PUBLIC_WALLET_LOGIN_ENDPOINT=/api/auth/wallet/login

# Google OAuth. The backend should return `{ data: { auth_url } }` or `{ auth_url }`
# from `${NEXT_PUBLIC_OAUTH_AUTHORIZE_ENDPOINT}/google?redirect_uri=...`, then accept
# `{ code, state }` at `${NEXT_PUBLIC_OAUTH_CALLBACK_ENDPOINT}/google/callback`.
NEXT_PUBLIC_OAUTH_AUTHORIZE_ENDPOINT=/api/v1/auth/oauth
NEXT_PUBLIC_OAUTH_CALLBACK_ENDPOINT=/api/v1/auth/oauth
